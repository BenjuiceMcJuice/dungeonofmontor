  "floors": {
    "grounds": {
      "id": "grounds", "name": "The Grounds", "order": 0,
      "zones": ["montors_garden"],
      "nextFloor": "underground",
      "transitionText": "You step through the gates. They close behind you.",
      "montorLine": "Welcome to my garden. Mind the flowers — they bite."
    },
    "underground": {
      "id": "underground", "name": "The Underground", "order": 1,
      "zones": ["great_hall", "kitchen"],
      "nextFloor": "underbelly",
      "transitionText": "The stone steps wind downward. The air grows cold and damp.",
      "montorLine": "You made it past the garden. How... persistent. Down here, things are less polite."
    },
    "underbelly": {
      "id": "underbelly", "name": "The Underbelly", "order": 2,
      "zones": ["sewers", "cistern"],
      "nextFloor": "quarters",
      "transitionText": "The walls are wet. Something drips. Something moves.",
      "montorLine": "The plumbing. Nobody comes down here. Nobody should."
    },
    "quarters": {
      "id": "quarters", "name": "The Quarters", "order": 3,
      "zones": ["bedroom", "study"],
      "nextFloor": "works",
      "transitionText": "Carpet underfoot. Portraits on the walls. Eyes that follow you.",
      "montorLine": "These are my private rooms. You are not welcome here. You were never welcome anywhere."
    },
    "works": {
      "id": "works", "name": "The Works", "order": 4,
      "zones": ["forge", "workshop"],
      "nextFloor": "deep",
      "transitionText": "Heat. The sound of grinding. Something is being built — or was, long ago.",
      "montorLine": "I made things here. Beautiful things. You wouldn't understand."
    },
    "deep": {
      "id": "deep", "name": "The Deep", "order": 5,
      "zones": ["caverns", "chasm"],
      "nextFloor": "domain",
      "transitionText": "The walls become rock. Natural. Ancient. Older than Montor. Older than anything.",
      "montorLine": "This was here before me. It'll be here after. I just... borrowed it."
    },
    "domain": {
      "id": "domain", "name": "Montor's Domain", "order": 6,
      "zones": ["throne_room"],
      "nextFloor": null,
      "transitionText": "A door. The last door. His door.",
      "montorLine": "You're here. Finally. I've been waiting. Sit down. Let's talk."
    }
  },
